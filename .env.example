# Firebase Configuration (opcional - para autenticação Firebase)
VITE_FIREBASE_API_KEY="sua_firebase_api_key"
VITE_FIREBASE_AUTH_DOMAIN="gameoab-45225.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="gameoab-45225"
